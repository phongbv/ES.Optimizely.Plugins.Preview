<?xml version="1.0" encoding="utf-8"?>
<module>
	<dojo>
		<!-- Add a mapping from Mosey to ~/ClientResources/Scripts to the dojo loader configuration -->
		<paths>
			<add name="previewButton" path="Scripts" />
		</paths>
	</dojo>
	<clientModule initializer="previewButton/Initialize">
		<moduleDependencies>
			<add dependency="CMS" type="RunAfter" />
		</moduleDependencies>
	</clientModule>
</module>